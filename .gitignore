# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
# MB-0(c): .expo/types (typed routes) y expo-env.d.ts SÍ se versionan — el CI
# typechequea sin dev server y los necesita. Regenerados por `expo start`;
# si cambian rutas, commitear el router.d.ts actualizado.
.expo/*
!.expo/types/
dist/
web-build/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Adicionales — security hardening
.env.production
.env.staging
supabase/.env
supabase/functions/.env
*.p8

# Sentry
sentry.properties
**/sentry.properties

# Cowork ↔ Claude Code: solo el buzón activo del momento se ignora (rota).
# Los reportes históricos y los buzones de cowork_handoff/ SÍ se versionan
# para trazabilidad de sprints (auditoría + historia del proyecto).
COWORK_TASK.md
COWORK_REPORT_FASE4.md

# Supabase CLI temp files (estado local del cli, no compartible)
supabase/.temp/

# Claude Code local settings
.claude/settings.local.json
